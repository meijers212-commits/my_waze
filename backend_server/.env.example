# תצורת ברירת מחדל ל-FastAPI של backend_server
#
# שים לב: הקובץ מיועד כדוגמה בלבד. אם תריץ מקומית, צור קובץ אמיתי בשם `.env`
# עם הערכים המתאימים.

# DB (MySQL)
SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:root@localhost:3306/grocery_app

# OCR (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# CORS (ללא שינוי עיצוב ב-client)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,https://my-waze.onrender.com

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
CREATE_TABLES_ON_STARTUP=true

